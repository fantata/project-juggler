APP_NAME="Project Juggler"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://project-juggler.test

ADMIN_EMAIL=admin@project-juggler.test
ADMIN_PASSWORD=password

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=project_juggler
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@project-juggler.test"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# AI Email Parsing (Groq - free tier available)
GROQ_API_KEY=

# GitHub Issues Sync (Personal Access Token with repo scope)
GITHUB_TOKEN=

# API IP Allowlist (comma-separated, production only — leave empty to allow all IPs)
# Add your home IP, VPN exit IP, etc. Example: 1.2.3.4,5.6.7.8
ALLOWED_API_IPS=

# Anthropic API key — used by the daily brief command for AI synthesis
ANTHROPIC_API_KEY=

# Daily brief — Fastmail passwords for IMAP access (same passwords as MCP email servers)
FASTMAIL_FANTATA_PASS=
FASTMAIL_DOGFACE_PASS=

# FreeAgent access tokens — get these from the token files on your local machine
# cat ~/Code/Projects/freeagent-mcp/.tokens-a.json | grep accessToken
# cat ~/Code/Projects/freeagent-mcp/.tokens-b.json | grep accessToken
FREEAGENT_FANTATA_ACCESS_TOKEN=
FREEAGENT_DOGFACE_ACCESS_TOKEN=
# Optional: path to token files (local dev only, overridden by ACCESS_TOKEN vars above)
FREEAGENT_FANTATA_TOKEN_FILE=/Users/chris/Code/Projects/freeagent-mcp/.tokens-a.json
FREEAGENT_DOGFACE_TOKEN_FILE=/Users/chris/Code/Projects/freeagent-mcp/.tokens-b.json
